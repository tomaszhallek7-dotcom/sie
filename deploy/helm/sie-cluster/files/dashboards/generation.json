        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(sie_gateway_generation_ttft_seconds_bucket{namespace=\"$namespace\"}[$rate_window]))) * 1000",
          "legendFormat": "gateway p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(sie_worker_generation_ttft_seconds_bucket{namespace=\"$namespace\"}[$rate_window]))) * 1000",
