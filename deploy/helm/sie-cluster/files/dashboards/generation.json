      "id": 41,
      "type": "timeseries",
      "title": "KV reserved tokens (worker reports vs gateway view)",
      "description": "Worker-side `sie_worker_generation_kv_reserved_tokens` is the source of truth; the gateway mirrors it as `sie_gateway_kv_reservation_known` so we can spot stale views. A widening gap means status envelopes are stalling.",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum by (model) (sie_worker_generation_kv_reserved_tokens{namespace=\"$namespace\"})",
          "legendFormat": "worker {{model}}",
          "refId": "A"
        },
        {
          "expr": "sum by (worker) (sie_gateway_kv_reservation_known{namespace=\"$namespace\"})",
          "legendFormat": "gateway view {{worker}}",
          "refId": "B"
        }
      ]
    },
