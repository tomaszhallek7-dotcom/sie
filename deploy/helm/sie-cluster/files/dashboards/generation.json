    {
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 17
      },
      "id": 22,
      "type": "timeseries",
      "title": "Stale-attempt chunks dropped / sec",
      "description": "JetStream-redelivered work after a worker crash generates a fresh attempt_id; if the gateway has already latched a different one, the late chunks are dropped and counted here. A sustained nonzero rate without corresponding pool churn means redelivery is happening but the pool-republish-driven attempt bumping isn't keeping up.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum by (model, pool) (rate(sie_gateway_generation_stale_attempt_chunks_total{namespace=\"$namespace\"}[$rate_window]))",
          "legendFormat": "{{model}} / {{pool}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
