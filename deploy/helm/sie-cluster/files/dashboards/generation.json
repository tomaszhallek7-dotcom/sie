    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 44
      },
      "id": 51,
      "type": "timeseries",
      "title": "Grammar cache hit rate",
      "description": "hits / (hits + misses). A sustained low rate (< 0.5) means clients are sending one-off schemas and the worker cache is not amortising compile cost.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum by (model) (rate(sie_worker_grammar_cache_hits_total{namespace=\"$namespace\"}[$rate_window])) / clamp_min(sum by (model) (rate(sie_worker_grammar_cache_hits_total{namespace=\"$namespace\"}[$rate_window]) + rate(sie_worker_grammar_cache_misses_total{namespace=\"$namespace\"}[$rate_window])), 1e-9)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
