    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "id": 30,
      "type": "timeseries",
      "title": "Routing fallbacks / sec by reason",
      "description": "Each HRW direct-dispatch miss attributes to one reason (unhealthy_skipped, saturated_skipped, no_key, nak_*, first_chunk_timeout). A sustained spike on `saturated_skipped` means admission high-water mark is too low; a spike on `unhealthy_skipped` means workers are flapping.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum by (reason) (rate(sie_gateway_routing_fallback_total{namespace=\"$namespace\"}[$rate_window]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "id": 31,
      "type": "timeseries",
      "title": "Routing cache-hit estimate (per model/pool)",
      "description": "Rolling-window estimate of routing-key → worker affinity. Higher is better — means consecutive requests with the same routing_key land on the same worker, maximising KV-cache reuse.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sie_gateway_routing_cache_hit_estimate{namespace=\"$namespace\"}",
          "legendFormat": "{{model}} / {{pool}}",
          "refId": "A"
        }
      ]
    },
